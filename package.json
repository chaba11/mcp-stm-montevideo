{
  "name": "mcp-stm-montevideo",
  "version": "0.1.7",
  "description": "MCP server for Montevideo's public bus network (STM) — consult stop schedules, routes and arrivals / Servidor MCP para el sistema de transporte de Montevideo",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-stm-montevideo": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "SKIP_INTEGRATION=false vitest run tests/integration/",
    "lint": "eslint src/ tests/",
    "start": "node dist/index.js",
    "start:api": "node dist/api/index.js",
    "dev:api": "tsx watch src/api/index.ts",
    "build-geo-data": "npx tsx scripts/fetch-mvd-osm-data.ts",
    "build-stm-data": "npx tsx scripts/fetch-stm-data.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaba11/mcp-stm-montevideo.git"
  },
  "keywords": [
    "mcp",
    "uruguay",
    "montevideo",
    "stm",
    "transporte",
    "bus",
    "omnibus",
    "open-data"
  ],
  "author": "chaba11",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/chaba11/mcp-stm-montevideo/issues"
  },
  "homepage": "https://landing.stm.paltickets.uy",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/swagger-ui": "^0.5.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "adm-zip": "^0.5.16",
    "csv-parse": "^6.1.0",
    "geolib": "^3.3.4",
    "hono": "^4.12.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
